* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: #f7f8fc;
  color: #111827;
}

button,
input,
textarea {
  font: inherit;
}

.app {
  width: 100%;
  min-height: 100vh;
  padding: 20px 16px 40px;
}

.hero {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
  padding: 24px 16px 10px;
}

.hero-badge {
  display: inline-block;
  padding: 8px 14px;
  border-radius: 999px;
  background: #e8f0ff;
  color: #2753d7;
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 16px;
}

.hero h1 {
  margin: 0;
  font-size: 34px;
  line-height: 1.1;
  font-weight: 800;
}

.hero-subtitle {
  margin: 14px auto 0;
  max-width: 620px;
  font-size: 16px;
  line-height: 1.6;
  color: #4b5563;
}

.hero-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 22px;
  flex-wrap: wrap;
}

.primary-btn,
.secondary-btn,
.submit-btn {
  border: none;
  border-radius: 14px;
  padding: 14px 18px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.primary-btn:hover,
.secondary-btn:hover,
.submit-btn:hover,
.mode-card:hover,
.character-card:hover,
.close-btn:hover {
  transform: translateY(-1px);
}

.primary-btn {
  background: #111827;
  color: white;
}

.secondary-btn {
  background: white;
  color: #111827;
  border: 1px solid #d1d5db;
}

.hero-note {
  margin-top: 14px;
  font-size: 14px;
  color: #6b7280;
}

.mode-section,
.content-section,
.info-section {
  max-width: 720px;
  margin: 24px auto 0;
}

.mode-section h2,
.section-header h2 {
  margin: 0 0 8px;
  font-size: 24px;
}

.section-header p {
  margin: 0;
  color: #6b7280;
  line-height: 1.5;
}

.mode-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: 16px;
}

.mode-card {
  width: 100%;
  border: 1.5px solid #e5e7eb;
  background: white;
  border-radius: 18px;
  padding: 16px;
  text-align: left;
  display: flex;
  gap: 14px;
  align-items: flex-start;
  cursor: pointer;
}

.mode-card.active {
  border-color: #5b7cff;
  background: #eef3ff;
}

.mode-icon {
  font-size: 24px;
  line-height: 1;
}

.mode-text {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mode-text strong {
  font-size: 17px;
}

.mode-text span {
  color: #6b7280;
  line-height: 1.5;
  font-size: 14px;
}

.content-card,
.info-card {
  background: white;
  border-radius: 22px;
  padding: 20px;
  margin-top: 16px;
  box-shadow: 0 10px 30px rgba(17, 24, 39, 0.06);
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group label {
  font-weight: 700;
}

.form-group input,
.form-group textarea {
  width: 100%;
  border: 1px solid #d1d5db;
  border-radius: 14px;
  padding: 14px;
  background: #fff;
}

.form-group textarea {
  resize: vertical;
  min-height: 120px;
}

.form-group small {
  color: #6b7280;
  line-height: 1.4;
}

.photo-preview {
  margin-top: 8px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #e5e7eb;
}

.photo-preview img {
  display: block;
  width: 100%;
  max-height: 320px;
  object-fit: cover;
}

.character-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.character-card {
  border: 1.5px solid #e5e7eb;
  border-radius: 16px;
  background: white;
  padding: 10px;
  cursor: pointer;
  text-align: center;
}

.character-card.selected {
  border-color: #5b7cff;
  background: #eef3ff;
}

.character-card img {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  border-radius: 12px;
  display: block;
}

.character-card span {
  display: block;
  margin-top: 8px;
  font-weight: 700;
  font-size: 14px;
}

.submit-btn {
  background: linear-gradient(135deg, #5b7cff, #7d5cff);
  color: white;
  padding: 16px;
  margin-top: 4px;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 10px;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.step-number {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: #111827;
  color: white;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}

.step p {
  margin: 2px 0 0;
  color: #4b5563;
  line-height: 1.5;
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
  z-index: 9999;
}

.modal-card {
  width: 100%;
  max-width: 420px;
  background: white;
  border-radius: 22px;
  padding: 16px;
  position: relative;
}

.close-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  border: none;
  background: #111827;
  color: white;
  width: 34px;
  height: 34px;
  border-radius: 999px;
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
}

.demo-header {
  padding-right: 40px;
  margin-bottom: 12px;
}

.demo-header h3 {
  margin: 0;
  font-size: 20px;
  line-height: 1.3;
}

.demo-video {
  display: block;
  width: 100%;
  border-radius: 16px;
  background: black;
}

@media (min-width: 768px) {
  .app {
    padding-top: 28px;
  }

  .hero h1 {
    font-size: 46px;
  }

  .hero-subtitle {
    font-size: 18px;
  }

  .mode-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .character-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
