@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap");

* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  min-height: 100%;
}

body {
  font-family: "Inter", sans-serif;
  background:
    radial-gradient(circle at top, rgba(255, 105, 145, 0.18), transparent 24%),
    linear-gradient(180deg, #07090f 0%, #0f1320 100%);
  color: #f5f7fb;
}

button,
input,
textarea {
  font: inherit;
}

button {
  border: none;
}

img,
video {
  display: block;
  max-width: 100%;
}

.app {
  width: 100%;
  max-width: 390px;
  margin: 0 auto;
  padding: 14px 14px 28px;
}

/* HERO */
.hero {
  text-align: center;
  padding: 6px 4px 14px;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #ff8eab;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.hero h1 {
  margin: 0;
  font-size: 28px;
  line-height: 1.05;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.subtitle {
  margin: 10px auto 0;
  color: #d3daea;
  font-size: 14px;
  line-height: 1.55;
  max-width: 340px;
}

/* SECTION */
.section {
  margin-top: 16px;
}

.section h2 {
  margin: 0 0 10px;
  font-size: 18px;
  font-weight: 800;
  letter-spacing: -0.02em;
}

/* PANELS */
.demoSection,
.cardWrap {
  background: rgba(20, 25, 40, 0.88);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  padding: 14px;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(10px);
}

/* DEMO */
.demoHeader {
  text-align: center;
  margin-bottom: 10px;
}

.demoSub {
  margin: 4px 0 0;
  color: #c9d1e0;
  font-size: 13px;
  line-height: 1.5;
}

.demoTabs,
.tabRow {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.demoTabs {
  margin-bottom: 12px;
}

.tabBtn {
  min-height: 38px;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.07);
  color: #f5f7fb;
  border: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
}

.tabBtn.active {
  background: linear-gradient(135deg, #ff5e87, #ff8aa5);
  border-color: transparent;
  color: white;
  box-shadow: 0 10px 22px rgba(255, 94, 135, 0.25);
}

.demoVideoWrap {
  width: 100%;
}

.demoVideo {
  width: 100%;
  aspect-ratio: 9 / 16;
  object-fit: cover;
  border-radius: 20px;
  background: #000;
  box-shadow: 0 14px 30px rgba(0, 0, 0, 0.35);
}

.demoVideo.contain {
  object-fit: contain;
  background: #000;
}

/* MODE */
.modeGrid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.modeCard {
  padding: 14px;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  text-align: left;
  color: #f5f7fb;
  cursor: pointer;
}

.modeCard.active {
  border-color: rgba(255, 94, 135, 0.9);
  box-shadow: 0 0 0 2px rgba(255, 94, 135, 0.14);
}

.modeTitle {
  font-size: 15px;
  font-weight: 800;
  margin-bottom: 4px;
  color: #ffffff;
}

.modeDesc {
  color: #d5dceb;
  font-size: 13px;
  line-height: 1.5;
}

/* TONE */
.toneGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.toneCard {
  padding: 12px;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  color: #f5f7fb;
  text-align: center;
  cursor: pointer;
}

.toneCard.active {
  border-color: rgba(255, 94, 135, 0.9);
  box-shadow: 0 0 0 2px rgba(255, 94, 135, 0.14);
}

.toneCard strong {
  display: block;
  margin-bottom: 4px;
  font-size: 14px;
  color: #ffffff;
}

.toneCard span {
  display: block;
  color: #d5dceb;
  font-size: 12px;
  line-height: 1.45;
}

/* INPUTS */
.label {
  display: block;
  margin: 0 0 6px;
  font-size: 13px;
  font-weight: 700;
  color: #ffffff;
}

.note {
  margin: 8px 0 12px;
  font-size: 12px;
  line-height: 1.5;
  color: #d3daea;
}

.input {
  width: 100%;
  min-height: 46px;
  margin-bottom: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(27, 33, 52, 0.95);
  color: #ffffff;
  outline: none;
  font-size: 14px;
}

.input::placeholder {
  color: #b7c0d3;
}

.input:focus {
  border-color: rgba(255, 94, 135, 0.9);
  box-shadow: 0 0 0 4px rgba(255, 94, 135, 0.12);
}

textarea.input {
  min-height: 96px;
  resize: vertical;
}

/* FORM GRID */
.formGrid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
}

/* PHOTO PREVIEW */
.previewBox {
  margin-top: 8px;
  width: 100%;
  max-width: 220px;
  overflow: hidden;
  border-radius: 18px;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.previewImage {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
}

/* CHARACTER */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 10px;
}

.card {
  padding: 8px;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  color: #f5f7fb;
  text-align: center;
  cursor: pointer;
}

.card.selected {
  border-color: rgba(255, 94, 135, 0.9);
  box-shadow: 0 0 0 2px rgba(255, 94, 135, 0.14);
}

.characterImage {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  border-radius: 14px;
}

.card p {
  margin: 8px 0 2px;
  font-size: 13px;
  font-weight: 700;
  color: #ffffff;
}

.selectedCharBox {
  margin-top: 12px;
  padding: 12px;
  border-radius: 16px;
  background: rgba(255, 94, 135, 0.12);
  border: 1px solid rgba(255, 94, 135, 0.45);
  color: #ffd9e3;
  font-size: 14px;
  font-weight: 700;
  text-align: center;
}

/* BUTTONS */
.createBtn {
  width: 100%;
  min-height: 48px;
  padding: 14px 16px;
  border-radius: 18px;
  background: linear-gradient(135deg, #ff5e87, #ff8aa5);
  color: #ffffff;
  font-size: 14px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  box-shadow: 0 16px 28px rgba(255, 94, 135, 0.24);
}

.createBtn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.statusMsg {
  margin: 0 0 10px;
  color: #ffd1dc;
  font-size: 13px;
}

/* DESKTOP PREVIEW */
@media (min-width: 768px) {
  .app {
    max-width: 400px;
    padding-top: 18px;
    padding-bottom: 34px;
  }
}

.infoSection {
  margin-top: 20px;
}

.row {
  display: flex;
  gap: 10px;
}

.row input {
  flex: 1;
}
